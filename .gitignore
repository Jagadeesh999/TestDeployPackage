# ============================================================
# .gitignore for TestDeployPackage
# ============================================================

# Build & dist output (generated by Jenkins/ABE - not stored in Git)
build/
dist/

# Backup files (generated during deployment)
backups/

# IDE / OS files
.DS_Store
Thumbs.db
*.iml
.idea/
.vscode/

# Temp and log files
*.log
*.tmp
*.bak

# Sensitive config (never commit credentials)
config/environments/*.secret
*.credentials